{
	"name": "tuto",
	"version": "0.1.0",
	"private": true,
	"description": "A visual, plain-language AI learning app",
	"packageManager": "pnpm@11.4.0",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "concurrently \"pnpm run hmr\" \"vite build && TUTO_HMR=1 electrobun dev\"",
		"hmr": "vite --port 5173",
		"build": "vite build && electrobun build",
		"typecheck": "tsc --noEmit",
		"smoke": "bun run scripts/tutor-smoke.ts",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@base-ui/react": "1.6.0",
		"@fontsource-variable/inter": "5.2.8",
		"@fontsource-variable/lora": "5.2.8",
		"@hugeicons/core-free-icons": "4.2.2",
		"@hugeicons/react": "1.1.9",
		"@shikijs/langs": "4.3.1",
		"@shikijs/themes": "4.3.1",
		"@tailwindcss/vite": "4.3.2",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"electrobun": "1.18.1",
		"mermaid": "11.16.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-markdown": "10.1.0",
		"shadcn": "4.13.0",
		"shiki": "4.3.1",
		"tailwind-merge": "3.6.0",
		"tailwindcss": "4.3.2",
		"tw-animate-css": "1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@tailwindcss/typography": "0.5.20",
		"@types/bun": "1.3.14",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.3",
		"concurrently": "10.0.3",
		"typescript": "7.0.2",
		"vite": "8.1.4"
	}
}
